# Copy this to .env and fill in your Notion token.
# Never commit .env to GitHub — it is already in .gitignore.

# Your Notion Integration Token
# Get from: https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Data Source IDs - pre-filled from your live Notion workspace
# These are the collection IDs inside each database, NOT the database page IDs
NOTION_ORG_DS=1cbecd67-4a69-81ae-bfcf-000b71cb2246
NOTION_CONTACT_DS=1cbecd67-4a69-81a0-a9d0-000b4656c90b
NOTION_MEETING_DS=aa6fdab3-b950-4d84-8983-e2673943833e
